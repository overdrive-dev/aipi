{
  "name": "aipi-workflow-lab-taskboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node dist-server/server.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run src",
    "test:e2e": "playwright test e2e/smoke.spec.ts",
    "check:baseline": "npm run typecheck && npm test && npm run build && npm run test:e2e",
    "eval:feature": "vitest run eval/feature.test.ts && playwright test eval/feature.e2e.spec.ts",
    "eval:bugfix": "vitest run eval/bugfix.test.ts",
    "eval:quick": "vitest run eval/quick.test.ts",
    "eval:ops": "vitest run eval/ops.test.ts"
  },
  "dependencies": {
    "express": "5.1.0",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/express": "5.0.3",
    "@types/node": "24.3.0",
    "@types/react": "19.1.10",
    "@types/react-dom": "19.1.7",
    "@types/supertest": "6.0.3",
    "@vitejs/plugin-react": "5.0.2",
    "supertest": "7.1.4",
    "typescript": "5.9.2",
    "vite": "7.3.6",
    "vitest": "3.2.7"
  }
}
